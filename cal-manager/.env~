# Google (service account with Calendar + impersonation scopes)
GOOGLE_SERVICE_ACCOUNT_FILE=/path/to/service-account.json

# Calendar IDs
WORK_CALENDAR_ID=primary
PERSONAL_CALENDAR_ID=your-personal-calendar-id@gmail.com

# Wife notifications
WIFE_EMAIL=kkutzke@gmail.com

# Working hours (24h, local time)
WORK_HOURS_START=9
WORK_HOURS_END=18
WORK_DAYS=0,1,2,3,4

# Locations (full street addresses for accurate travel time)
HOME_ADDRESS=123 Main St, Your City, State 00000
WORK_ADDRESS=456 Office Blvd, Your City, State 00000
TIMEZONE=America/Chicago

# Google Maps (for travel time calculation)
GOOGLE_MAPS_API_KEY=

# Database
DATABASE_URL=postgresql://localhost/cal_manager

# Scheduling
POLL_INTERVAL_MINUTES=30
LOOKAHEAD_DAYS=14

# Chrome extension API
API_PORT=5555
API_SECRET=change-me
