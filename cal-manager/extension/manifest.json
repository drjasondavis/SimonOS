{
  "manifest_version": 3,
  "name": "Cal Manager — Suggest Times",
  "version": "1.0",
  "description": "Insert available meeting times into Gmail compose windows.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": [
    "https://mail.google.com/*",
    "http://localhost:5555/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
