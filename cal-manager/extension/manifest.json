{
  "manifest_version": 3,
  "name": "Cal Manager — Scheduler",
  "version": "2.0",
  "description": "Suggest meeting times or create calendar events directly from Gmail.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": [
    "https://mail.google.com/*",
    "http://localhost:5555/*",
    "http://127.0.0.1:5555/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
