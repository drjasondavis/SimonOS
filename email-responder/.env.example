# Anthropic
ANTHROPIC_API_KEY=

# Identity (used in reply drafting)
USER_NAME=Jason
COMPANY_NAME=Simon AI

# Timezone
TIMEZONE=America/Chicago

# Working hours (used by scheduling handler)
WORK_HOURS_START=9
WORK_HOURS_END=18
WORK_DAYS=0,1,2,3,4

# Database URL — must point to the same DB as cal-manager so the scheduling
# handler can read calendar events for free-slot detection
DATABASE_URL=postgresql://localhost/cal_manager

# API server (Chrome extension connects here)
API_PORT=5556
API_SECRET=change-me
