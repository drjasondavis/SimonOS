# Project-specific config — shared Google credentials live in root .env

# Internal email domains (comma-separated, no spaces)
INTERNAL_DOMAINS=yourcompany.com,yourcompany.io

# Google Calendar & Drive (project-specific IDs)
GOOGLE_CALENDAR_IDS=primary,another-calendar-id@group.calendar.google.com
GOOGLE_DRIVE_SALES_DECKS_FOLDER_IDS=folder-id-1,folder-id-2

# Gong
GONG_API_KEY=
GONG_API_SECRET=

# Salesforce
SALESFORCE_USERNAME=
SALESFORCE_PASSWORD=
SALESFORCE_SECURITY_TOKEN=
SALESFORCE_DOMAIN=login

# Database
DATABASE_URL=postgresql://localhost/customer_convos

# Job settings
CALENDAR_POLL_INTERVAL_MINUTES=60
CALENDAR_LOOKBACK_DAYS=7
