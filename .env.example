# Shared credentials — copy to .env and fill in values
# Each project will also have its own .env for project-specific config

# Google (service account with domain-wide delegation)
GOOGLE_SERVICE_ACCOUNT_FILE=/path/to/SimonOS/credentials/service-account.json
GOOGLE_IMPERSONATE_EMAIL=you@yourcompany.com

# Google OAuth (personal Gmail — run cal-manager/scripts/authorize_personal.py once)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_PERSONAL_REFRESH_TOKEN=

# Google Maps
GOOGLE_MAPS_API_KEY=
